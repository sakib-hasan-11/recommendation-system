# =============================================================================
# RECOMMENDATION SYSTEM - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains secrets!
# For production/cloud deployment, add these secrets to GitHub Actions
# =============================================================================

# Environment
ENV=production
DEBUG=False
LOG_LEVEL=INFO

# =============================================================================
# 🔒 AWS CREDENTIALS (GITHUB SECRETS REQUIRED)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# =============================================================================
# 📦 S3 CONFIGURATION (GITHUB SECRETS REQUIRED)
# =============================================================================
S3_BUCKET=recommendation-system-prod
S3_INGESTION_PREFIX=raw-data
S3_PROCESSED_PREFIX=processed-data
S3_MODELS_PREFIX=models
S3_FEAST_PREFIX=feast-repo

# =============================================================================
# 🔴 REDIS CONFIGURATION (GITHUB SECRETS REQUIRED)
# =============================================================================
# For cloud: Use AWS ElastiCache endpoint
REDIS_HOST=recommendation-system-redis.xxxxx.ng.0001.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_if_auth_enabled
CACHE_TTL=3600

# =============================================================================
# 🔑 PINECONE CONFIGURATION (GITHUB SECRETS REQUIRED)
# =============================================================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=recommendations-prod
PINECONE_ENVIRONMENT=us-east-1-aws

# =============================================================================
# 📊 MLFLOW CONFIGURATION (GITHUB SECRETS REQUIRED)
# =============================================================================
MLFLOW_TRACKING_URI=http://your-mlflow-server.com
MLFLOW_EXPERIMENT_NAME=recommendation-system-prod
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=s3://your-s3-bucket/mlflow-artifacts

# =============================================================================
# AWS BATCH CONFIGURATION (For Batch Job Execution)
# =============================================================================
AWS_BATCH_COMPUTE_ENVIRONMENT=recommendation-compute-env
AWS_BATCH_JOB_QUEUE=recommendation-job-queue
AWS_BATCH_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/recommendation-batch-role
AWS_BATCH_JOB_DEFINITION=recommendation-job

# =============================================================================
# Feast Configuration
# =============================================================================
FEAST_REPO_PATH=./feast_repo/feature_repo
FEAST_OFFLINE_STORE=file
FEAST_ONLINE_STORE=redis

# =============================================================================
# Model Configuration
# =============================================================================
EMBEDDING_DIM=128
HIDDEN_UNITS=512
LEARNING_RATE=0.001
BATCH_SIZE=64
EPOCHS=20
VALIDATION_SPLIT=0.15
TEST_SPLIT=0.15

# =============================================================================
# Feature Engineering
# =============================================================================
RECALL_AT_K=10
NDCG_AT_K=10
MIN_RATINGS_PER_USER=5
MIN_INTERACTIONS_PER_ITEM=5

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=False

# =============================================================================
# Streamlit Configuration
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
API_ENDPOINT=http://localhost:8000

# =============================================================================
# Data Configuration
# =============================================================================
DATA_LOCAL_PATH=./data_local
TRAINING_DATA_PATH=./data/training
PROCESSED_DATA_PATH=./data/processed

# =============================================================================
# Optuna Configuration
# =============================================================================
OPTUNA_N_TRIALS=50
OPTUNA_N_JOBS=4
OPTUNA_TIMEOUT=3600

# =============================================================================
# Logging
# =============================================================================
LOG_FORMAT=json
LOG_FILE=./logs/app.log
